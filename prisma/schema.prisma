generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Server {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  ip           String
  backendPort  Int
  frontendPort Int      @unique
  createdAt    DateTime @default(now())

  @@unique([ip, backendPort])
}

model LockdownEvent {
  id        Int      @id @default(autoincrement())
  action    String
  source    String
  reason    String?
  ipCount   Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}
